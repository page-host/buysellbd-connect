{
  "rewrites": [
    { "source": "/(.*)\\.png", "destination": "/$1.png" },
    { "source": "/(.*)\\.jpg", "destination": "/$1.jpg" },
    { "source": "/(.*)", "destination": "/" }
  ],
  "headers": [
    {
      "source": "/(.*)\\.png",
      "headers": [
        {
          "key": "Content-Type",
          "value": "image/png"
        }
      ]
    }
  ]
}